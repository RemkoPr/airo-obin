(module JST_PH_1x02_RightAngle_SMD_P2.00mm (layer F.Cu) (tedit 0)
  (descr "JST PH 2-pin right-angle SMD, 2.00 mm pitch — footprint for Adafruit LiPo battery connector (matches 2-pin JST PH cable)")
  (tags "jst ph 2 pin right-angle smd 2.00mm")

  ;; reference/name
  (fp_text reference J1 (at 0 -3.5) (layer F.SilkS) (effects (font (size 1 1) (thickness 0.15))))
  (fp_text value JST_PH_1x02_RA (at 0 3.5) (layer F.Fab) (effects (font (size 1 1) (thickness 0.15))))

  ;; silkscreen outline (simple box)
  (fp_line (start -3.5 -2.5) (end 1.5 -2.5) (layer F.SilkS) (width 0.12))
  (fp_line (start 1.5 -2.5) (end 1.5 2.5) (layer F.SilkS) (width 0.12))
  (fp_line (start 1.5 2.5) (end -3.5 2.5) (layer F.SilkS) (width 0.12))
  (fp_line (start -3.5 2.5) (end -3.5 -2.5) (layer F.SilkS) (width 0.12))

  ;; courtyard (0.25 mm margin outside body)
  (fp_line (start -4.0 -3.0) (end 2.0 -3.0) (layer F.CrtYd) (width 0.05))
  (fp_line (start 2.0 -3.0) (end 2.0 3.0) (layer F.CrtYd) (width 0.05))
  (fp_line (start 2.0 3.0) (end -4.0 3.0) (layer F.CrtYd) (width 0.05))
  (fp_line (start -4.0 3.0) (end -4.0 -3.0) (layer F.CrtYd) (width 0.05))

  ;; fabrication outline (approx body)
  (fp_line (start -3.0 -2.0) (end 1.0 -2.0) (layer F.Fab) (width 0.1))
  (fp_line (start 1.0 -2.0) (end 1.0 2.0) (layer F.Fab) (width 0.1))
  (fp_line (start 1.0 2.0) (end -3.0 2.0) (layer F.Fab) (width 0.1))
  (fp_line (start -3.0 2.0) (end -3.0 -2.0) (layer F.Fab) (width 0.1))

  ;; pads: two SMD pads for right-angle JST PH header
  ;; pad geometry chosen to match common B2B-PH-SM4-TB style

  (pad 1 smd rect (at -1.0 0) (size 1.8 1.4) (layers F.Cu F.Paste F.Mask) (solder_mask_margin 0.05) (drill_rect (size 0 0)))
  (pad 2 smd rect (at 1.0 0) (size 1.8 1.4) (layers F.Cu F.Paste F.Mask) (solder_mask_margin 0.05) (drill_rect (size 0 0)))

  ;; mechanical stabiliser / keep-out SMD pads (optional) — small anchor pads
  (pad 3 smd roundrect (at -2.5 0) (size 1.2 1.2) (layers F.Cu F.Paste F.Mask) (solder_mask_margin 0.05))
  (pad 4 smd roundrect (at 2.5 0) (size 1.2 1.2) (layers F.Cu F.Paste F.Mask) (solder_mask_margin 0.05))

  ;; polarity mark on silkscreen near pin1
  (fp_text user BAT+ (at -1 2.8) (layer F.SilkS) (effects (font (size 0.9 0.9) (thickness 0.12))))

)
